E2B_API_KEY=****

# Daytona organization id that prod's DAYTONA_API_KEY is scoped to.
# scripts/create-template.ts refuses to build unless the Daytona CLI's
# active org matches this value, so snapshots never land in the wrong
# namespace (prior outages: #129, #136).
# Find yours with: `daytona organization list`
DAYTONA_PROD_ORG_ID=
